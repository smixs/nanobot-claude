#!/usr/bin/env bash
# Mock systemctl/loginctl/nanobot for install.sh testing without
# running real systemd inside the container.
case "${0##*/}" in
  systemctl)
    # enable --now, daemon-reload, is-active — just succeed and log
    echo "[mock systemctl] $*" >&2
    case "$*" in
      "--user is-active nanobot"|"--user is-active claude-shim") exit 0 ;;
    esac
    exit 0
    ;;
  loginctl)
    # pretend linger is already on so install.sh skips that path
    if [ "$1" = "show-user" ]; then echo "Linger=yes"; exit 0; fi
    exit 0
    ;;
  nanobot)
    # only called is `nanobot onboard` → produce a minimal config
    if [ "${1:-}" = "onboard" ]; then
      mkdir -p "$HOME/.nanobot"
      cat > "$HOME/.nanobot/config.json" <<'JSON'
{"providers":{"custom":{"apiBase":"","apiKey":""}},
 "agents":{"defaults":{"model":"","timezone":""}},
 "channels":{"telegram":{"enabled":false,"token":"","allowFrom":[],"streaming":false}}}
JSON
      exit 0
    fi
    if [ "${1:-}" = "--version" ]; then echo "nanobot 0.0.0 (mock)"; exit 0; fi
    exit 0
    ;;
esac
echo "mock: unknown wrapper ${0##*/}" >&2
exit 1
